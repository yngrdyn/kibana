    "@kbn/apm-types",
    "@kbn/core-http-browser",
    "@kbn/deeplinks-observability",
    "@kbn/share-plugin",
    "@kbn/react-hooks",
    "@kbn/core",
    "@kbn/apm-api-shared",
    "@kbn/elastic-agent-utils",
    "@kbn/core-chrome-layout-constants",
    "@kbn/apm-common",
