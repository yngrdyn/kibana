{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types"
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["target/**/*"],
  "kbn_references": [
    "@kbn/i18n",
    "@kbn/i18n-react",
    "@kbn/charts-theme",
    "@kbn/apm-types-shared",
