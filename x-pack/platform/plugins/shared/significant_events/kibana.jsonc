{
  "type": "plugin",
  "id": "@kbn/significant-events-plugin",
  "owner": "@elastic/obs-sig-events-team",
  "description": "Significant Events",
  "group": "platform",
  "visibility": "shared",
  "plugin": {
    "id": "significant_events",
    "configPath": ["xpack", "significant_events"],
    "browser": true,
    "server": true,
    "requiredPlugins": [
      "actions",
      "alerting",
      "alertingVTwo",
      "console",
      "data",
      "encryptedSavedObjects",
      "features",
      "inference",
      "licensing",
      "security",
      "streams",
      "taskManager",
      "usageCollection",
      "fieldsMetadata"
    ],
    "optionalPlugins": [
      "agentBuilder",
      "agentBuilderSml",
      "cloud",
      "esql",
      "serverless",
      "globalSearch",
      "searchInferenceEndpoints",
      "spaces",
      "workflowsExtensions",
      "workflowsManagement"
    ],
    "requiredBundles": [],
    "extraPublicDirs": ["common"]
  }
}
